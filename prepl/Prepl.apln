:Namespace Prepl
вНЭ Prepl: A programmable REPL server for Dyalog APL
вНЭ Inspired by Clojure's prepl
вНЭ
вНЭ Protocol (pure APLAN):
вНЭ   Input:  APL expression, newline-terminated
вНЭ   Output: APLAN namespace, newline-terminated:
вНЭ     (tag: 'ret' вЛД val: 1 2 3)         вАФ return value
вНЭ     (tag: 'ret')                        вАФ no displayable result (shy/void)
вНЭ     (tag: 'err' вЛД en: 11 вЛД message: 'DOMAIN ERROR' вЛД dm: (...))
вНЭ
вНЭ Usage:
вНЭ   2 вОХFIX 'file:///path/to/Prepl.apln'
вНЭ   Prepl.Start 4200          вНЭ blocking
вНЭ   Prepl.LoadConga            вНЭ pre-load on main thread (вОХCY needs thread 0)
вНЭ   tidвЖРPrepl.Start&4200      вНЭ on new thread (& is an operator: f&arg)
вНЭ
вНЭ Loads Conga from workspace if needed.

    вОХIOвЖР1

    LDRCвЖРвНђ           вНЭ Conga instance (set by LoadConga)
    _stopвЖР0          вНЭ Stop flag
    _bufвЖР''          вНЭ Receive buffer (v1: single connection)

    вНЭ вФАвФА Server Lifecycle вФАвФА

    вИЗ LoadConga
    вНЭ Load and initialize Conga. Copies from ws if not already present.
      :If 9вЙ†вМК#.вОХNC'Conga'
          'Conga'#.вОХCY'conga'
      :EndIf
      LDRCвЖР#.Conga.Init'prepl'
    вИЗ

    вИЗ Start port;z
      _stopвЖР0
      _bufвЖР''
      :If вНђвЙ°LDRC вЛД LoadConga вЛД :EndIf   вНЭ Skip if pre-loaded by bootstrap
      :Trap 0 вЛД {}LDRC.Close'prepl' вЛД :EndTrap
      zвЖРLDRC.Srv'prepl' '' port 'Raw' 4096
      :If 0вЙ†вКГz
          вОХвЖР'Prepl: failed to start on port ',вНХport
          :Return
      :EndIf
      вОХвЖР'Prepl listening on port ',вНХport
      Loop
    вИЗ

    вИЗ Stop
      _stopвЖР1
    вИЗ

    вИЗ Loop;wres;rc;obj;evt;data
      :While ~_stop
          wresвЖРLDRC.Wait'prepl' 5000
          :If 0вЙ†1вКГwres
              :If 100вЙ°1вКГwres вЛД :Continue вЛД :EndIf   вНЭ Timeout (rc=100)
              вОХвЖР'Prepl: wait error ',вНХwres
              :Leave
          :EndIf
          (rc obj evt data)вЖР4вЖСwres
          :Trap 0
              :Select evt
              :Case 'Connect'
                  _bufвЖР''
              :Case 'Block'
                  obj HandleBlock data
              :Case 'BlockLast'
                  obj HandleBlock data
              :Case 'Closed'
                  _bufвЖР''
              :Case 'Error'
                  _bufвЖР''
              :EndSelect
          :Else
              вОХвЖР'Prepl event error:' вОХDMX.(EN Message)
          :EndTrap
      :EndWhile
      {}LDRC.Close'prepl'
      вОХвЖР'Prepl stopped'
    вИЗ

    вИЗ obj HandleBlock data;text;idx;expr;response;id
    вНЭ Buffer incoming data and process complete lines
      textвЖР'UTF-8'вОХUCS data
      _buf,вЖРtext
      :While (вОХUCS 10)вИК_buf
          idxвЖР_bufвН≥вОХUCS 10
          exprвЖР(idx-1)вЖС_buf
          _bufвЖРidxвЖУ_buf
          :If (0<вЙҐexpr)вИІ(вОХUCS 13)=вКГвМљexpr    вНЭ Strip CR from CRLF
              exprвЖР¬ѓ1вЖУexpr
          :EndIf
          :If 0<вЙҐexpr
              idвЖРExtractID expr
              responseвЖРEval expr               вНЭ вНЭID: is a comment вАФ вНО ignores it
              :If 0<вЙҐid
                  responseвЖР'(id: ''',id,''' вЛД ',(1вЖУresponse)
              :EndIf
              {}LDRC.Send obj('UTF-8'вОХUCS response,вОХUCS 10)
          :EndIf
      :EndWhile
    вИЗ

    вИЗ idвЖРExtractID expr;pos
    вНЭ Extract optional ID from trailing comment: expr вНЭID:uuid
    вНЭ Returns '' if no вНЭID: found.
      idвЖР''
      posвЖР('вНЭID:'вНЈexpr)/вН≥вЙҐexpr
      :If 0<вЙҐpos
          idвЖР((вКГpos)+3)вЖУexpr
      :EndIf
    вИЗ

    вНЭ вФАвФА Evaluation вФАвФА

    вИЗ rвЖРEval expr;вОХPW;вОХPP
      вОХPWвЖР32767 вЛД вОХPPвЖР17
      вНЭ Execute in # context. Result in #.вНЩr (not local вАФ Serialise
      вНЭ can't resolve namespace refs held in local variables).
      :Trap 0
          :With #
              вНЩrвЖРвНОexpr
          :EndWith
      :Else
          :If 6=вОХDMX.EN
              rвЖР'(tag: ''ret'')'
          :Else
              rвЖРErrAPLAN вОХDMX
          :EndIf
          вЖТCLEANUP
      :EndTrap
      вНЭ Serialize вАФ three levels: APLAN, display form, literal fallback
      :Trap 0
          rвЖР'(tag: ''ret'' вЛД val: ',(ToAPLAN #.вНЩr),')'
      :Else
          :Trap 0
              rвЖР'(tag: ''ret'' вЛД val: ',(ToAPLANвНХ#.вНЩr),')'
          :Else
              rвЖР'(tag: ''ret'')'
          :EndTrap
      :EndTrap
     CLEANUP:
      :Trap 0 вЛД #.вОХEX'вНЩr' вЛД :EndTrap
    вИЗ

    вИЗ rвЖРErrAPLAN dmx
    вНЭ (tag: 'err' вЛД en: 11 вЛД message: 'DOMAIN ERROR' вЛД dm: (...))
      rвЖР'(tag: ''err'''
      r,вЖР' вЛД en: ',(вНХdmx.EN)
      r,вЖР' вЛД message: ',(ToAPLAN dmx.Message)
      r,вЖР' вЛД dm: ',(ToAPLAN dmx.DM)
      r,вЖР')'
    вИЗ

    вНЭ вФАвФА APLAN Serialization вФАвФА
    вНЭ вОХSE.Dyalog.Array.Serialise вЖТ lines, 62583вМґ вЖТ compact single-line.

    вИЗ rвЖРToAPLAN v
      rвЖР1(62583вМґ)вОХSE.Dyalog.Array.Serialise v
    вИЗ

:EndNamespace
